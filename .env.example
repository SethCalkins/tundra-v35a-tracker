# Copy to .env and adjust for your machine.

# ── Database ───────────────────────────────────────────────────
# Used by scraper (SQLAlchemy) AND dashboard (node-postgres).
# Defaults match docker-compose.yml.
DATABASE_URL=postgresql://tundra:tundra@localhost:5434/tundra

# ── Scraper ────────────────────────────────────────────────────
# Throttle between Playwright navigations (seconds). Be polite.
CARVANA_REQUEST_DELAY_SECONDS=25

# UA the scraper presents. Keep it realistic.
CARVANA_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36"

# Cap pages crawled per run (safety net while iterating)
CARVANA_MAX_PAGES=20

# ── Recall poller ──────────────────────────────────────────────
# If the public NHTSA API turns out to only expose recall *eligibility*
# and not *completion*, flip this on to use the toyota.com/recall fallback.
RECALL_POLLER_USE_TOYOTA_FALLBACK=false

# ── Dashboard ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
